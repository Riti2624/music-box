# Copy this file to .env and fill in values as needed
# Public key example (safe to commit)
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__

# Optional app message
PING_MESSAGE=ping pong

# Postgres (required for share metadata and ownership)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# S3-compatible object storage (S3, Cloudflare R2, Supabase S3)
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Optional custom endpoint for non-AWS providers (e.g. R2/Supabase)
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
